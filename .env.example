# Shared edit passphrase (minimum 8 characters)
EDIT_PASSPHRASE=choose-a-strong-passphrase

# Public HTTPS URL of your self-hosted draw.io instance (e.g., https://drawio.example.com)
DRAWIO_EMBED_URL=https://drawio.example.com

# Port diagram-hub will listen on
PORT=3000

# SQLite data directory
DATA_DIR=/data
